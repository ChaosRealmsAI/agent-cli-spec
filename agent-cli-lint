check_N1() {
  local names; names=$(_get_command_names)
  if [[ -z "$names" ]]; then
    emit_result "N1" "skip" "No commands in schema"
    return
  fi
  emit_result "N1" "pass" "Command naming consistency (manual review recommended)"
}

check_N2() {
  if ! _has_describe_schema; then
    # Can still check command names from --help for camelCase
    local names; names=$(_get_command_names)
    if [[ -z "$names" ]]; then
      emit_result "N2" "skip" "No flag definitions to check kebab-case"
      return
    fi
    local bad=""
    while IFS= read -r name; do
      [[ -z "$name" ]] && continue
      if [[ "$name" =~ [A-Z] ]]; then
        bad="$bad $name"
      fi
    done <<< "$names"
    if [[ -z "$bad" ]]; then
      emit_result "N2" "pass" "All command names use kebab-case"
    else
      emit_result "N2" "fail" "Non-kebab-case names:$bad" \
        "Use kebab-case for all names."
    fi
    return
  fi
  # Check all flags are kebab-case
  local all_flags; all_flags=$(echo "$DESCRIBE_CACHE" | jq -r '
    [.commands[]?.parameters[]?.name // empty, .global_flags[]? // empty] | .[]' 2>/dev/null)
  local bad=""
  while IFS= read -r flag; do
    [[ -z "$flag" ]] && continue
    flag="${flag#--}"
    if [[ "$flag" =~ [A-Z] ]]; then
      bad="$bad --$flag"
    fi
  done <<< "$all_flags"
  if [[ -z "$bad" ]]; then
    emit_result "N2" "pass" "All flags use kebab-case"
  else
    emit_result "N2" "fail" "Non-kebab-case flags:$bad" \
      "Use --output-format not --outputFormat."
  fi
}

check_N3() {
  local max_depth=0
  local cmds; cmds=$(_get_command_names)
  if [[ -z "$cmds" ]]; then
    emit_result "N3" "skip" "No commands to check depth"
    return
  fi
  while IFS= read -r cmd; do
    [[ -z "$cmd" ]] && continue
    local depth; depth=$(echo "$cmd" | tr ' ' '\n' | wc -l | tr -d ' ')
    [[ $depth -gt $max_depth ]] && max_depth=$depth
  done <<< "$cmds"
  if [[ $max_depth -le 3 ]]; then
    emit_result "N3" "pass" "Max command depth: $max_depth (≤ 3)"
  else
    emit_result "N3" "fail" "Command depth $max_depth exceeds 3" \
      "Keep commands to max 3 levels: mycli resource action."
  fi
}

check_N4() {
  local reserved=("--agent" "--human" "--brief" "--help" "--version" "--yes" "--dry-run" "--quiet" "--fields")
  local found=0
  # Check from --describe global_flags first
  local global_flags; global_flags=$(echo "$DESCRIBE_CACHE" | jq -r '.global_flags[]? // empty' 2>/dev/null)
  if [[ -n "$global_flags" ]]; then
    for flag in "${reserved[@]}"; do
      if echo "$global_flags" | grep -qF -- "$flag" 2>/dev/null; then
        found=$((found + 1))
      fi
    done
  else
    # No global_flags in schema — test actual flag support by probing
    for flag in "${reserved[@]}"; do
      case "$flag" in
        --help)    [[ "$HELP_EXIT" -eq 0 ]] && found=$((found + 1)) ;;
        --version) [[ -n "$VERSION_CACHE" ]] && found=$((found + 1)) ;;
        --brief)   [[ "$BRIEF_EXIT" -eq 0 && -n "$BRIEF_CACHE" ]] && found=$((found + 1)) ;;
        *)
          # Quick probe: run with the flag, if exit != 2 (UNKNOWN_FLAG), it's supported
          local probe_out probe_err
          probe_err=$(eval "$TARGET_CLI $flag" 2>&1 >/dev/null || true)
          if ! echo "$probe_err" | jq -e '.code == "UNKNOWN_FLAG" or .code == "PARAM_ERROR"' >/dev/null 2>&1; then
            found=$((found + 1))
          fi
          ;;
      esac
    done
  fi
  if [[ $found -ge 4 ]]; then
    emit_result "N4" "pass" "Reserved flags present ($found/${#reserved[@]})"
  else
    emit_result "N4" "fail" "Only $found/${#reserved[@]} reserved flags found" \
      "Support: --agent, --human, --brief, --help, --version, --yes, --dry-run, --quiet, --fields."
  fi
}

check_N5() {
  if [[ "$HELP_EXIT" -eq 0 ]] && [[ -n "$HELP_CACHE" ]]; then
    emit_result "N5" "pass" "--help produces output"
  else
    emit_result "N5" "fail" "--help not working" \
      "Add --help flag."
  fi
