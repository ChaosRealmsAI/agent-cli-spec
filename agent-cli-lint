        {"name": "rule", "type": "string", "required": false, "description": "Check single rule by ID (e.g. O1)"}
      ],
      "output": {"type": "object", "properties": {"tool": "string", "scope": "object", "summary": "object", "layers": "array", "certification": "object", "dimensions": "array"}}
    },
    {
