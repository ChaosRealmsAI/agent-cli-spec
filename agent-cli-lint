cmd_skills() {
  local name="${1:-}"
  if [[ -z "$name" ]]; then
    output_json "$(agent_skills_json)"
    return
  fi

  local skill_file="$SCRIPT_DIR/agent/skills/$name.md"
  if [[ ! -f "$skill_file" ]]; then
    error_json "NOT_FOUND" \
      "Skill not found: $name" \
      "Available: $(ls "$SCRIPT_DIR/agent/skills/" 2>/dev/null | sed 's/.md$//' | paste -sd', ')" 20
  fi

  local description; description=$(read_frontmatter_description "$skill_file")
  local content; content=$(cat "$skill_file")

  local skill_json
  skill_json=$(jq -n \
    --arg name "$name" \
    --arg description "$description" \
    --arg content "$content" \
    '{name: $name, description: $description, content: $content}')
  output_json "$skill_json"
}

# ═══════════════════════════════════════════════════════════
# D10 Feedback: issue subcommand
# ═══════════════════════════════════════════════════════════
cmd_issue() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    create) cmd_issue_create "$@" ;;
    list)   cmd_issue_list ;;
    show)   cmd_issue_show "$@" ;;
    "")     error_json "MISSING_PARAM" "Missing subcommand for issue" "Usage: agent-cli-lint issue <create|list|show>" 2 ;;
    *)      error_json "UNKNOWN_COMMAND" "Unknown issue subcommand: $subcmd" "Available: create, list, show" 2 ;;
  esac
}

cmd_issue_create() {
  local type="" message=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)    [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --type requires a value" "" 2; type="$2"; shift 2 ;;
      --message) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --message requires a value" "" 2; message="$2"; shift 2 ;;
      *)         error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --type, --message" 2 ;;
    esac
  done
  [[ -n "$type" ]]    || error_json "MISSING_PARAM" "Missing: --type" "Options: bug, requirement, suggestion, bad-output" 2
  [[ -n "$message" ]] || error_json "MISSING_PARAM" "Missing: --message" "Describe the issue." 2
  case "$type" in
    bug|requirement|suggestion|bad-output) ;;
    *) error_json "INVALID_ENUM" "Invalid issue type: $type" "Valid: bug, requirement, suggestion, bad-output" 2 ;;
  esac
  validate_input "$message" "message"
  ensure_dirs
  local id="iss-$(date +%s)-$((RANDOM % 1000))"
  local created; created=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local issue; issue=$(jq -n --arg id "$id" --arg type "$type" --arg message "$message" \
    --arg version "$VERSION" --arg created "$created" --arg updated "$created" --arg status "open" \
    '{id:$id, type:$type, message:$message, version:$version, status:$status, created:$created, created_at:$created, updated_at:$updated}')
  echo "$issue" > "$ISSUES_DIR/$id.json"
  log "Issue created: $id"
  if wants_json_output; then output_json "$issue"; fi
}

cmd_issue_list() {
  ensure_dirs
  local issues="[]"
  for f in "$ISSUES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    issues=$(echo "$issues" | jq --slurpfile entry "$f" '. + $entry')
  done
  output_list "$issues"
}

cmd_issue_show() {
  local id="${1:-}"
  [[ -n "$id" ]] || error_json "MISSING_PARAM" "Missing: issue ID" "Usage: agent-cli-lint issue show <id>" 2
  local file="$ISSUES_DIR/$id.json"
  [[ -f "$file" ]] || error_json "NOT_FOUND" "Issue not found: $id" "Use: agent-cli-lint issue list" 20
  output_json "$(cat "$file")"
}

# ═══════════════════════════════════════════════════════════
# Check Infrastructure
# ═══════════════════════════════════════════════════════════

# Temp file for stderr capture
TMP_STDERR=""
TMP_STDOUT=""
cleanup() { rm -f "$TMP_STDERR" "$TMP_STDOUT" 2>/dev/null; }

# macOS-compatible timeout (bash 3.2 safe, suppresses job control messages)
run_with_timeout() {
  local secs="$1"; shift
  local cmd_output cmd_err
  cmd_output=$(mktemp)
  cmd_err=$(mktemp)

  # Run in subshell to suppress bash job control messages
  TIMEOUT_STDOUT=""
  TIMEOUT_STDERR=""
  TIMEOUT_EXIT=0
  (
    eval "$@" > "$cmd_output" 2> "$cmd_err" &
    local pid=$!
    ( sleep "$secs" && kill -9 "$pid" 2>/dev/null ) &
    local watcher=$!
    wait "$pid" 2>/dev/null
    local rc=$?
    kill "$watcher" 2>/dev/null
    wait "$watcher" 2>/dev/null || true
    exit $rc
  ) 2>/dev/null
  TIMEOUT_EXIT=$?

  TIMEOUT_STDOUT=$(cat "$cmd_output" 2>/dev/null)
  TIMEOUT_STDERR=$(cat "$cmd_err" 2>/dev/null)
  rm -f "$cmd_output" "$cmd_err"
  return 0
}

# Results accumulator
declare -a RESULTS=()
ACTIVE_DIMENSION=""
ACTIVE_LAYER=""
ACTIVE_PRIORITY=""
ACTIVE_RULE=""

emit_result() {
  local id="$1" status="$2" detail="$3" suggestion="${4:-}"
  local sug_field=""
  [[ -n "$suggestion" ]] && sug_field=", \"suggestion\": $(printf '%s' "$suggestion" | jq -Rs .)"
  RESULTS+=("{\"id\": \"$id\", \"status\": \"$status\", \"detail\": $(printf '%s' "$detail" | jq -Rs .)$sug_field}")
}

declare -a RULE_REGISTRY=()

load_rule_registry() {
  RULE_REGISTRY=()
  [[ -f "$RULES_FILE" ]] || error_json "INTERNAL_ERROR" "Missing rule registry: $RULES_FILE" "Restore data/rules.tsv." 1

  while IFS='|' read -r rid rname rdim rdname rpri rlayer rfunc; do
    [[ -z "$rid" || "$rid" == \#* ]] && continue
    RULE_REGISTRY+=("$rid|$rname|$rdim|$rdname|$rpri|$rlayer|$rfunc")
  done < "$RULES_FILE"
}

# Filter compiler/runtime noise from stderr mixed into stdout
# Handles: cargo (Compiling/Finished/Running/Blocking/Downloading/warning:),
#           bun ($ prefix lines), and other build tool noise
_filter_compiler_noise() {
  sed -E \
    -e '/^[[:space:]]*(Compiling|Finished|Running|Blocking|Downloading|Downloaded|Updating|Unpacking|Resolving|Packaging|Documenting|Locking|Linking|Fresh|Checking) /d' \
    -e '/^[[:space:]]*warning\[/d' \
    -e '/^[[:space:]]*warning:/d' \
    -e '/^\$/d' \
    -e '/^[[:space:]]*\$/d'
}

# Target CLI state (cached after discover)
TARGET_CLI=""
TARGET_DIR=""
DESCRIBE_CACHE=""
DESCRIBE_EXIT=0
HELP_CACHE=""
HELP_EXIT=0
BRIEF_CACHE=""
BRIEF_EXIT=0
VERSION_CACHE=""

discover_target() {
  local cli="$1"
  TARGET_CLI="$cli"

  # Resolve directory for static checks
  local resolved
  resolved=$(which "$cli" 2>/dev/null || echo "$cli")
  if [[ -f "$resolved" ]]; then
    TARGET_DIR=$(cd "$(dirname "$(realpath "$resolved" 2>/dev/null || echo "$resolved")")" && pwd)
  else
    # Multi-word command (e.g. "bun run src/main.ts") — try last arg
    local last_word="${cli##* }"
    if [[ -f "$last_word" ]]; then
      TARGET_DIR=$(cd "$(dirname "$(realpath "$last_word" 2>/dev/null || echo "$last_word")")" && pwd)
    else
      TARGET_DIR="."
    fi
  fi

  # For cargo/bun commands, also look for project root via manifest
  if [[ "$cli" == *"--manifest-path"* ]]; then
    local manifest_path
    manifest_path=$(echo "$cli" | grep -oE '\-\-manifest-path [^ ]+' | awk '{print $2}')
    if [[ -n "$manifest_path" && -f "$manifest_path" ]]; then
      TARGET_DIR=$(cd "$(dirname "$(realpath "$manifest_path" 2>/dev/null || echo "$manifest_path")")" && pwd)
    fi
  fi

  log "Discovering: $cli"
  log "Target dir: $TARGET_DIR"

  # Cache --help (primary discovery, per new spec)
  HELP_CACHE=$(eval "$cli --help" 2>&1 | _filter_compiler_noise || echo '{}')
  # Validate it's JSON
  if echo "$HELP_CACHE" | jq -e '.' >/dev/null 2>&1; then
    HELP_EXIT=0
  else
    HELP_CACHE='{}'
    HELP_EXIT=1
  fi

  # Cache --describe (backward compat fallback)
  DESCRIBE_CACHE=$(eval "$cli --describe" 2>/dev/null | _filter_compiler_noise || echo '{}')
  if echo "$DESCRIBE_CACHE" | jq -e '.' >/dev/null 2>&1; then
    DESCRIBE_EXIT=0
  else
    DESCRIBE_CACHE='{}'
    DESCRIBE_EXIT=1
  fi

  # Cache --brief
  BRIEF_CACHE=$(eval "$cli --brief" 2>/dev/null | _filter_compiler_noise || echo '')
  BRIEF_EXIT=$?

  # Cache --version
  VERSION_CACHE=$(eval "$cli --version" 2>/dev/null | _filter_compiler_noise || echo '')
}

# Helper: get combined command names from HELP_CACHE or DESCRIBE_CACHE
_get_command_names() {
  local names=""
  # Try HELP_CACHE first (new spec: .commands[].name)
  if [[ "$HELP_EXIT" -eq 0 ]]; then
    names=$(echo "$HELP_CACHE" | jq -r '.commands[]?.name // empty' 2>/dev/null)
  fi
  # Fallback to DESCRIBE_CACHE
  if [[ -z "$names" ]] && [[ "$DESCRIBE_EXIT" -eq 0 ]]; then
    names=$(echo "$DESCRIBE_CACHE" | jq -r '.commands[]?.name // empty' 2>/dev/null)
  fi
  echo "$names"
}

# Helper: check if we have detailed schema info (from --describe)
_has_describe_schema() {
  [[ "$DESCRIBE_EXIT" -eq 0 ]] && echo "$DESCRIBE_CACHE" | jq -e '.commands[0].parameters // .commands[0].destructive // .commands[0].output' >/dev/null 2>&1
}

# Helper: get tool name from best available source
_get_tool_name() {
  local name=""
  name=$(echo "$DESCRIBE_CACHE" | jq -r '.name // empty' 2>/dev/null)
  if [[ -z "$name" ]]; then
    # Extract from --help .help field (first word or before " — ")
    name=$(echo "$HELP_CACHE" | jq -r '.help // empty' 2>/dev/null | sed -E 's/ — .*//' | awk '{print $1}')
  fi
  if [[ -z "$name" ]]; then
    name="unknown"
  fi
  echo "$name"
}

# Helper: get tool version from best available source
_get_tool_version() {
  local ver=""
  ver=$(echo "$DESCRIBE_CACHE" | jq -r '.version // empty' 2>/dev/null)
  if [[ -z "$ver" && -n "$VERSION_CACHE" ]]; then
    ver="$VERSION_CACHE"
  fi
  if [[ -z "$ver" ]]; then
    ver="unknown"
  fi
  echo "$ver"
}

# Helper: find a non-destructive list-like command from help or describe schema
find_list_command() {
  # Try DESCRIBE_CACHE first (has destructive info)
  if _has_describe_schema; then
    local result
    result=$(echo "$DESCRIBE_CACHE" | jq -r '
      .commands[]? |
      select(.destructive == false or .destructive == null) |
      select(.name == "list" or .name == "models" or .name == "status" or .name == "voices" or .name == "skills") |
      .name' 2>/dev/null | head -1)
    [[ -n "$result" ]] && echo "$result" && return

    result=$(echo "$DESCRIBE_CACHE" | jq -r '
      .commands[]? |
      select(.destructive == false or .destructive == null) |
      select([.parameters[]? | select(.required == true)] | length == 0) |
      select(.name != "issue" and .name != "check" and .name != "snapshot" and .name != "diff" and .name != "ai-prompts") |
      .name' 2>/dev/null | head -1)
    [[ -n "$result" ]] && echo "$result" && return
  fi
  # Fallback: search by name only from any source
  _get_command_names | while IFS= read -r name; do
    case "$name" in
      list|models|status|voices|skills) echo "$name"; return ;;
    esac
  done
}

# Helper: find a destructive command
find_destructive_command() {
  # Only works with DESCRIBE_CACHE (needs destructive annotation)
  if _has_describe_schema; then
    echo "$DESCRIBE_CACHE" | jq -r '
      .commands[]? |
      select(.destructive == true) |
      .name' 2>/dev/null | head -1
  fi
}

# Helper: find a show-like command
find_show_command() {
  local candidates="show get info"
  if _has_describe_schema; then
    echo "$DESCRIBE_CACHE" | jq -r '
      .commands[]? |
      select(.name == "show" or .name == "get" or .name == "info") |
      .name' 2>/dev/null | head -1
    return
  fi
  _get_command_names | while IFS= read -r name; do
    case "$name" in
      show|get|info) echo "$name"; return ;;
    esac
  done
}

# Helper: find a command with required string param (for type/guardrail tests)
find_command_with_required_param() {
  # Only works with DESCRIBE_CACHE (needs parameter info)
  if _has_describe_schema; then
    echo "$DESCRIBE_CACHE" | jq -r '
      .commands[]? |
      select(.destructive == false or .destructive == null) |
      select(.name != "check" and .name != "snapshot" and .name != "diff" and .name != "ai-prompts") |
      select(.parameters? | length > 0) |
      select(.parameters[]? | .required == true) |
      .name' 2>/dev/null | head -1
  fi
}

schema_flag_supported() {
  local cmd="$1" param="$2" value="${3:-lint-probe}"
  run_cli "$cmd --$param $value --json"
  local err_source="$RUN_STDERR"
  [[ -z "$err_source" ]] && err_source="$RUN_STDOUT"
  local code; code=$(echo "$err_source" | jq -r '.code // empty' 2>/dev/null)
  [[ "$code" == "UNKNOWN_FLAG" ]] && return 1
  return 0
}

# Helper: run CLI and capture stdout/stderr/exit separately
run_cli() {
  local stdout_file stderr_file
  stdout_file=$(mktemp)
  stderr_file=$(mktemp)

  eval "$TARGET_CLI $*" > "$stdout_file" 2> "$stderr_file"
  local rc=$?

  RUN_STDOUT=$(cat "$stdout_file" 2>/dev/null | _filter_compiler_noise)
  RUN_STDERR=$(cat "$stderr_file" 2>/dev/null | _filter_compiler_noise)
  RUN_EXIT=$rc
  rm -f "$stdout_file" "$stderr_file"
  return 0
}

LIST_CMD=""

require_list_command() {
  local rule_id="$1" skip_detail="$2"
  LIST_CMD=$(find_list_command)
  if [[ -z "$LIST_CMD" ]]; then
    emit_result "$rule_id" "skip" "$skip_detail"
    return 1
  fi
  return 0
}

run_list_command() {
  local args="${1:-}"
  if [[ -n "$args" ]]; then
    run_cli "$LIST_CMD $args"
  else
    run_cli "$LIST_CMD"
  fi
}

stdout_is_json() {
  echo "$RUN_STDOUT" | jq . >/dev/null 2>&1
}

ERROR_SOURCE=""

capture_error_probe() {
  run_cli "--nonexistent-flag-xyz"
  ERROR_SOURCE="$RUN_STDERR"
  [[ -z "$ERROR_SOURCE" ]] && ERROR_SOURCE="$RUN_STDOUT"
  if [[ -n "$ERROR_SOURCE" ]]; then
    return 0
  fi

  run_cli "" 2>/dev/null
  ERROR_SOURCE="$RUN_STDERR"
  [[ -z "$ERROR_SOURCE" ]] && ERROR_SOURCE="$RUN_STDOUT"
}

