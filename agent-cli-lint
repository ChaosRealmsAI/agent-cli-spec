#!/usr/bin/env bash
# agent-cli-lint — Agent-Friendly CLI Spec v0.1 Compliance Checker
# This tool itself complies with the spec it enforces (dogfooding).
set -euo pipefail

VERSION="0.1.0"
SPEC_VERSION="0.1"
LINT_DIR="${AGENT_CLI_LINT_DIR:-$HOME/.agent-cli-lint}"
ISSUES_DIR="$LINT_DIR/issues"
SNAPSHOTS_DIR="$LINT_DIR/snapshots"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RULES_FILE="$SCRIPT_DIR/data/rules.tsv"

# ═══════════════════════════════════════════════════════════
# D07 Composability: stderr for logs, stdout for data only
# ═══════════════════════════════════════════════════════════
QUIET=false
OUTPUT_JSON=false
FORCE_HUMAN=false
FIELDS=""
log() { [[ "$QUIET" == true ]] && return; echo "$*" >&2; }

# ═══════════════════════════════════════════════════════════
# D03 Structured Error: { error, code, message, suggestion }
# ═══════════════════════════════════════════════════════════
error_json() {
  local code="$1" message="$2" suggestion="${3:-}" exit_code="${4:-1}"
  local sug_field=""
  [[ -n "$suggestion" ]] && sug_field=", \"suggestion\": $(printf '%s' "$suggestion" | jq -Rs .)"
  printf '{"error": true, "code": "%s", "message": %s%s}\n' \
    "$code" "$(printf '%s' "$message" | jq -Rs .)" "$sug_field" >&2
  exit "$exit_code"
}

# ═══════════════════════════════════════════════════════════
# D11 Guardrails: Runtime protection
# ═══════════════════════════════════════════════════════════
check_secret() {
  local val="$1" param="$2"
  if [[ "$val" =~ ^(sk-|pk-|ghp_|gho_|github_pat_|xoxb-|xoxp-|AKIA) ]] ||
     [[ "$val" =~ ^(eyJ[A-Za-z0-9]) ]] ||
     [[ ${#val} -gt 30 && "$val" =~ ^[A-Za-z0-9+/=_-]+$ && ! "$val" =~ [.:/] ]]; then
    error_json "SECRET_DETECTED" \
      "Parameter --$param looks like an API key or token" \
      "Never pass secrets as CLI arguments." 2
  fi
}

check_path() {
  local val="$1" param="$2"
  if [[ "$val" =~ \.\. ]] || [[ "$val" =~ ^/ ]]; then
    error_json "PATH_TRAVERSAL" \
      "Parameter --$param contains path traversal or absolute path" \
      "Use relative paths without .. components." 2
  fi
  local base; base=$(basename "$val")
  if [[ "$base" =~ ^\.env ]] || [[ "$base" =~ \.key$ ]] || [[ "$base" =~ \.pem$ ]] ||
     [[ "$base" =~ secret ]] || [[ "$base" =~ password ]]; then
    error_json "SENSITIVE_PATH" \
      "Parameter --$param points to a sensitive file: $base" \
      "Avoid operating on credential or secret files." 2
  fi
}

check_shell_meta() {
  local val="$1" param="$2"
  if [[ "$val" =~ [\;\|\&\$\`] ]] || [[ "$val" =~ \$\( ]]; then
    error_json "SHELL_INJECTION" \
      "Parameter --$param contains shell metacharacters" \
      "Remove ; | & \$ \` characters from the value." 2
  fi
}

validate_input() {
  local val="$1" param="$2"
  check_shell_meta "$val" "$param"
  check_secret "$val" "$param"
  if [[ "$val" =~ [[:cntrl:]] ]] && ! [[ "$val" =~ ^[[:print:][:space:]]*$ ]]; then
    error_json "CONTROL_CHAR" \
      "Parameter --$param contains control characters" \
      "Remove non-printable characters from the value." 2
  fi
}

# ═══════════════════════════════════════════════════════════
# Data layer
# ═══════════════════════════════════════════════════════════
ensure_dirs() {
  mkdir -p "$LINT_DIR" "$ISSUES_DIR" "$SNAPSHOTS_DIR"
}

is_tty() { [[ -t 1 ]]; }

wants_json_output() {
  [[ "$OUTPUT_JSON" == true ]] && return 0
  [[ "$FORCE_HUMAN" == true ]] && return 1
  ! is_tty
}

# ═══════════════════════════════════════════════════════════
# D02 Structured Output
# ═══════════════════════════════════════════════════════════
filter_fields() {
  if [[ -n "$FIELDS" ]]; then
    local parts=()
    IFS=',' read -ra field_arr <<< "$FIELDS"
    local obj_parts=()
    for f in "${field_arr[@]}"; do
      obj_parts+=("\"$f\": .$f")
    done
    local obj_expr; obj_expr=$(IFS=','; echo "${obj_parts[*]}")
    jq "{$obj_expr}"
  else
    jq '.'
  fi
}

agent_issue_guide() {
  printf '%s' "Any problem, bad output, or confusion — run: agent-cli-lint issue create --type <bug|requirement|suggestion|bad-output> --message '...'"
}

read_frontmatter_description() {
  local file="$1"
  awk '
    BEGIN { in_fm = 0 }
    NR == 1 && $0 == "---" { in_fm = 1; next }
    in_fm && $0 == "---" { exit }
    in_fm && $0 ~ /^description:[[:space:]]*/ {
      sub(/^description:[[:space:]]*/, "", $0)
      print $0
      exit
    }
  ' "$file"
}

agent_rules_json() {
  local rules=()
  if [[ -d "$SCRIPT_DIR/agent/rules" ]]; then
    for f in "$SCRIPT_DIR/agent/rules"/*.md; do
      [[ -f "$f" ]] || continue
      local name; name=$(basename "$f" .md)
      local content; content=$(cat "$f")
      rules+=("{\"name\": $(printf '%s' "$name" | jq -Rs .), \"content\": $(printf '%s' "$content" | jq -Rs .)}")
    done
  fi
  local rules_json; rules_json=$(IFS=','; echo "[${rules[*]:-}]")
  echo "$rules_json"
}

agent_skills_json() {
  local skills=()
  if [[ -d "$SCRIPT_DIR/agent/skills" ]]; then
    for f in "$SCRIPT_DIR/agent/skills"/*.md; do
      [[ -f "$f" ]] || continue
      local name description
      name=$(basename "$f" .md)
      description=$(read_frontmatter_description "$f")
      skills+=("{\"name\": $(printf '%s' "$name" | jq -Rs .), \"description\": $(printf '%s' "$description" | jq -Rs .), \"command\": $(printf 'agent-cli-lint skills %s' "$name" | jq -Rs .)}")
    done
  fi
  local skills_json; skills_json=$(IFS=','; echo "[${skills[*]:-}]")
  echo "$skills_json"
}

attach_agent_context() {
  local data="$1"
  local rules_json skills_json issue_text
  rules_json=$(agent_rules_json)
  skills_json=$(agent_skills_json)
  issue_text=$(agent_issue_guide)
  echo "$data" | jq \
    --argjson rules "$rules_json" \
    --argjson skills "$skills_json" \
    --arg issue "$issue_text" \
    'if type == "array"
     then {result: ., rules: $rules, skills: $skills, issue: $issue}
     else . + {rules: $rules, skills: $skills, issue: $issue}
     end'
}

output_json() {
  local data="$1"
  data=$(attach_agent_context "$data")
  if [[ -n "$FIELDS" ]]; then
    echo "$data" | filter_fields
  else
    echo "$data" | jq '.'
  fi
}

output_list() {
  local data="$1"
  if wants_json_output; then
    data=$(attach_agent_context "$data")
    if [[ -n "$FIELDS" ]]; then
      echo "$data" | filter_fields
    else
      echo "$data" | jq '.'
    fi
  else
    echo "$data" | jq -r '.[] | "  \(.id // "-")  \(.status // "-")  \(.detail // "-")"'
    local count; count=$(echo "$data" | jq 'length')
    log "  ($count items)"
  fi
}

# ═══════════════════════════════════════════════════════════
# D01 Discoverability: --help, --describe, skills
# ═══════════════════════════════════════════════════════════
cmd_help() {
  local brief="" rules=() skills=()

  if [[ -f "$SCRIPT_DIR/agent/brief.md" ]]; then
    brief=$(cat "$SCRIPT_DIR/agent/brief.md")
  fi
  if [[ -d "$SCRIPT_DIR/agent/rules" ]]; then
    for f in "$SCRIPT_DIR/agent/rules"/*.md; do
      [[ -f "$f" ]] || continue
      local name; name=$(basename "$f" .md)
      local content; content=$(cat "$f")
      rules+=("{\"name\": $(printf '%s' "$name" | jq -Rs .), \"content\": $(printf '%s' "$content" | jq -Rs .)}")
    done
  fi
  if [[ -d "$SCRIPT_DIR/agent/skills" ]]; then
    for f in "$SCRIPT_DIR/agent/skills"/*.md; do
      [[ -f "$f" ]] || continue
      local name; name=$(basename "$f" .md)
      skills+=("{\"name\": $(printf '%s' "$name" | jq -Rs .), \"command\": \"agent-cli-lint skills $name\"}")
    done
  fi

  local rules_json; rules_json=$(IFS=','; echo "[${rules[*]:-}]")
  local skills_json; skills_json=$(IFS=','; echo "[${skills[*]:-}]")

  local help_json
  help_json=$(jq -n \
    --arg help "$brief" \
    --argjson rules "$rules_json" \
    --argjson skills "$skills_json" \
    '{
      help: $help,
      version: "'"$VERSION"'",
      commands: [
        {"name": "check", "description": "Check CLI compliance against spec rules"},
        {"name": "snapshot", "description": "Save schema and error code snapshot"},
        {"name": "diff", "description": "Compare current vs saved snapshot"},
        {"name": "ai-prompts", "description": "Generate AI check prompts for non-automatable rules"},
        {"name": "issue", "description": "Feedback system (create/list/show)"},
        {"name": "skills", "description": "View available skills"}
      ],
      layers: [
        {"name": "core", "description": "Minimum execution contract: JSON, errors, exit codes, stdout/stderr separation, safety guardrails"},
        {"name": "recommended", "description": "Machine-friendly ergonomics: self-description, explicit flags, pipe-safe UX, richer safety semantics"},
        {"name": "ecosystem", "description": "Agent-native ecosystem contract: agent metadata, skills, feedback workflow, inline context"}
      ],
      rules: $rules,
      skills: $skills,
      issue: "Any problem, bad output, or confusion — run: agent-cli-lint issue create --type <bug|requirement|suggestion|bad-output> --message '\''...'\''",
    }')
  output_json "$help_json"
}

cmd_brief() {
  if [[ -f "$SCRIPT_DIR/agent/brief.md" ]]; then
    cat "$SCRIPT_DIR/agent/brief.md"
  else
    error_json "NOT_FOUND" "agent/brief.md not found" "Create agent/brief.md at the project root." 20
  fi
}

cmd_describe() {
  local describe_json
  describe_json=$(cat <<'SCHEMA'
{
  "name": "agent-cli-lint",
  "version": "0.1.0",
  "description": "Agent-Friendly CLI Spec v0.1 compliance checker",
  "commands": [
    {
