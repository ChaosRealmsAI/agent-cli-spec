  if [[ -n "$ver" ]] && [[ "$ver" =~ ^[0-9]+\.[0-9]+ ]]; then
    emit_result "N6" "pass" "--version outputs semver: $ver"
  elif [[ -n "$ver" ]]; then
    emit_result "N6" "fail" "--version output not semver: $ver" \
