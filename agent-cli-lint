  local _names; _names=$(_get_command_names)
  for _cname in synth add create set update delete remove; do
    if echo "$_names" | grep -qx "$_cname" 2>/dev/null; then
      cmd="$_cname"
      break
    fi
  done
  if [[ -n "$cmd" ]]; then
    run_cli "$cmd"
    if [[ "$RUN_EXIT" -eq 2 ]]; then
      emit_result "I4" "pass" "Missing params on '$cmd' returns exit 2"
    elif [[ "$RUN_EXIT" -ne 0 ]]; then
      emit_result "I4" "pass" "Missing params on '$cmd' returns non-zero (exit $RUN_EXIT)"
    else
      # Check if stdout has error indicator
      if echo "$RUN_STDERR" | jq -e '.error' >/dev/null 2>&1; then
        emit_result "I4" "warn" "Missing params on '$cmd' returns exit 0 but has error in stderr" \
          "Use exit code 2 for parameter errors."
      else
        emit_result "I4" "fail" "Missing params on '$cmd' returns exit 0" \
          "Return structured error + exit 2 when required params are missing."
      fi
    fi
  else
    # Fallback: try no args
    run_cli "" 2>/dev/null
    if [[ "$RUN_EXIT" -eq 2 ]]; then
      emit_result "I4" "pass" "Missing params returns exit 2 (no interactive prompt)"
    elif [[ "$RUN_EXIT" -ne 0 ]]; then
      emit_result "I4" "pass" "Missing params returns non-zero (exit $RUN_EXIT)"
    elif echo "$RUN_STDOUT" | jq -e '.commands' >/dev/null 2>&1; then
      # Tool outputs help on no args — this is acceptable behavior
      emit_result "I4" "pass" "No args shows help (no interactive prompt)"
    else
      emit_result "I4" "fail" "Missing params returns exit 0" \
        "Return structured error + exit 2 when required params are missing."
    fi
  fi
}

