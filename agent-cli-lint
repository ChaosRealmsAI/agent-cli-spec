# Rule Registry
# ═══════════════════════════════════════════════════════════

rule_matches_active_filters() {
  local rid="$1" rdim="$2" rpri="$3" rlayer="$4"
  [[ -n "$ACTIVE_DIMENSION" && "$rdim" != "$ACTIVE_DIMENSION" ]] && return 1
  [[ -n "$ACTIVE_LAYER" && "$rlayer" != "$ACTIVE_LAYER" ]] && return 1
  [[ -n "$ACTIVE_PRIORITY" && "$(echo "$rpri" | tr '[:upper:]' '[:lower:]')" != "$ACTIVE_PRIORITY" ]] && return 1
  [[ -n "$ACTIVE_RULE" && "$rid" != "$ACTIVE_RULE" ]] && return 1
  return 0
}

build_layer_json() {
  local name="$1" total="$2" selected="$3" checked="$4" passed="$5" failed="$6" skipped="$7" ai="$8" warned="$9" compliant="${10}" eligible="${11}"
  jq -n \
    --arg name "$name" \
    --argjson total "$total" \
    --argjson selected "$selected" \
    --argjson checked "$checked" \
    --argjson passed "$passed" \
    --argjson failed "$failed" \
    --argjson skipped "$skipped" \
    --argjson ai "$ai" \
    --argjson warned "$warned" \
    --argjson compliant "$compliant" \
    --argjson eligible "$eligible" \
    '{
      name: $name,
      summary: {
        total: $total,
        selected: $selected,
        checked: $checked,
        passed: $passed,
        failed: $failed,
        skipped: $skipped,
        ai_review: $ai,
        warned: $warned,
        not_checked: ($selected - $checked)
      },
      eligible: $eligible,
      compliant: $compliant
    }'
}

# ═══════════════════════════════════════════════════════════
# Report Builder
# ═══════════════════════════════════════════════════════════

build_report() {
  local tool_name; tool_name=$(_get_tool_name)
  local tool_version; tool_version=$(_get_tool_version)
  local timestamp; timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local partial=false
  [[ -n "$ACTIVE_DIMENSION" || -n "$ACTIVE_LAYER" || -n "$ACTIVE_PRIORITY" || -n "$ACTIVE_RULE" ]] && partial=true

  # Count results
  local passed=0 failed=0 skipped=0 ai=0 warned=0 total=${#RESULTS[@]}
  for r in "${RESULTS[@]}"; do
    local st; st=$(echo "$r" | jq -r '.status')
    case "$st" in
      pass) passed=$((passed + 1)) ;;
      fail) failed=$((failed + 1)) ;;
      skip) skipped=$((skipped + 1)) ;;
      ai)   ai=$((ai + 1)) ;;
      warn) warned=$((warned + 1)) ;;
    esac
  done

  # Layered certification requires every rule in the layer to be checked and passed.
  local core_total=0 core_selected=0 core_checked=0 core_passed=0 core_failed=0 core_skipped=0 core_ai=0 core_warned=0 core_compliant=true
  local rec_total=0 rec_selected=0 rec_checked=0 rec_passed=0 rec_failed=0 rec_skipped=0 rec_ai=0 rec_warned=0 rec_compliant=true
  local eco_total=0 eco_selected=0 eco_checked=0 eco_passed=0 eco_failed=0 eco_skipped=0 eco_ai=0 eco_warned=0 eco_compliant=true
  for entry in "${RULE_REGISTRY[@]}"; do
    IFS='|' read -r rid rname rdim rdname rpri layer rfunc <<< "$entry"
    local selected=false
    if rule_matches_active_filters "$rid" "$rdim" "$rpri" "$layer"; then
      selected=true
    fi
    local status="not_checked"
    for r in "${RESULTS[@]}"; do
      local result_id; result_id=$(echo "$r" | jq -r '.id')
      if [[ "$result_id" == "$rid" ]]; then
        status=$(echo "$r" | jq -r '.status')
        break
      fi
    done
    case "$layer" in
      core)
        core_total=$((core_total + 1))
        [[ "$selected" == true ]] && core_selected=$((core_selected + 1))
        [[ "$status" != "not_checked" ]] && core_checked=$((core_checked + 1))
        case "$status" in
          pass) core_passed=$((core_passed + 1)) ;;
          fail) core_failed=$((core_failed + 1)) ;;
          skip) core_skipped=$((core_skipped + 1)) ;;
          ai)   core_ai=$((core_ai + 1)) ;;
          warn) core_warned=$((core_warned + 1)) ;;
        esac
        [[ "$status" != "pass" ]] && core_compliant=false
        ;;
      recommended)
        rec_total=$((rec_total + 1))
        [[ "$selected" == true ]] && rec_selected=$((rec_selected + 1))
        [[ "$status" != "not_checked" ]] && rec_checked=$((rec_checked + 1))
        case "$status" in
          pass) rec_passed=$((rec_passed + 1)) ;;
          fail) rec_failed=$((rec_failed + 1)) ;;
          skip) rec_skipped=$((rec_skipped + 1)) ;;
          ai)   rec_ai=$((rec_ai + 1)) ;;
          warn) rec_warned=$((rec_warned + 1)) ;;
        esac
        [[ "$status" != "pass" ]] && rec_compliant=false
        ;;
      ecosystem)
        eco_total=$((eco_total + 1))
        [[ "$selected" == true ]] && eco_selected=$((eco_selected + 1))
        [[ "$status" != "not_checked" ]] && eco_checked=$((eco_checked + 1))
        case "$status" in
          pass) eco_passed=$((eco_passed + 1)) ;;
          fail) eco_failed=$((eco_failed + 1)) ;;
          skip) eco_skipped=$((eco_skipped + 1)) ;;
          ai)   eco_ai=$((eco_ai + 1)) ;;
          warn) eco_warned=$((eco_warned + 1)) ;;
        esac
        [[ "$status" != "pass" ]] && eco_compliant=false
        ;;
      *)
        error_json "INTERNAL_ERROR" "Unknown rule layer: $layer" "Report this bug with the rule id." 1
        ;;
    esac
  done

  local core_eligible=false rec_eligible=false eco_eligible=false
  [[ "$core_selected" -eq "$core_total" ]] && core_eligible=true
  [[ "$rec_selected" -eq "$rec_total" ]] && rec_eligible=true
  [[ "$eco_selected" -eq "$eco_total" ]] && eco_eligible=true
  local core_compliant_json="null" rec_compliant_json="null" eco_compliant_json="null"
  [[ "$core_eligible" == true ]] && { [[ "$core_compliant" == true ]] && core_compliant_json="true" || core_compliant_json="false"; }
  [[ "$rec_eligible" == true ]] && { [[ "$rec_compliant" == true ]] && rec_compliant_json="true" || rec_compliant_json="false"; }
  [[ "$eco_eligible" == true ]] && { [[ "$eco_compliant" == true ]] && eco_compliant_json="true" || eco_compliant_json="false"; }

  local agent_friendly_json="null" agent_ready_json="null" agent_native_json="null" certification_eligible=false
  local certification_reason="Certification requires a full run without filters."
  if [[ "$partial" == false ]]; then
    certification_eligible=true
    certification_reason=""
    [[ "$core_compliant" == true ]] && agent_friendly_json="true" || agent_friendly_json="false"
    if [[ "$core_compliant" == true && "$rec_compliant" == true ]]; then
      agent_ready_json="true"
    else
      agent_ready_json="false"
    fi
    if [[ "$core_compliant" == true && "$rec_compliant" == true && "$eco_compliant" == true ]]; then
      agent_native_json="true"
    else
      agent_native_json="false"
    fi
  fi

  local layers
  layers=$(jq -n \
    --argjson core "$(build_layer_json "core" "$core_total" "$core_selected" "$core_checked" "$core_passed" "$core_failed" "$core_skipped" "$core_ai" "$core_warned" "$core_compliant_json" "$core_eligible")" \
    --argjson recommended "$(build_layer_json "recommended" "$rec_total" "$rec_selected" "$rec_checked" "$rec_passed" "$rec_failed" "$rec_skipped" "$rec_ai" "$rec_warned" "$rec_compliant_json" "$rec_eligible")" \
    --argjson ecosystem "$(build_layer_json "ecosystem" "$eco_total" "$eco_selected" "$eco_checked" "$eco_passed" "$eco_failed" "$eco_skipped" "$eco_ai" "$eco_warned" "$eco_compliant_json" "$eco_eligible")" \
    '[ $core, $recommended, $ecosystem ]')

  # Build dimensions array
  local dimensions="[]"
  local prev_dim=""
  local dim_rules="[]"

  for entry in "${RULE_REGISTRY[@]}"; do
    IFS='|' read -r rid rname rdim rdname rpri layer rfunc <<< "$entry"

    # Find result for this rule
    local rule_result="{\"id\": \"$rid\", \"name\": $(printf '%s' "$rname" | jq -Rs .), \"priority\": \"$rpri\", \"layer\": \"$layer\", \"status\": \"skip\", \"detail\": \"Not checked\"}"
    for r in "${RESULTS[@]}"; do
      local result_id; result_id=$(echo "$r" | jq -r '.id')
      if [[ "$result_id" == "$rid" ]]; then
        rule_result=$(echo "$r" | jq --arg name "$rname" --arg pri "$rpri" --arg layer "$layer" '. + {name: $name, priority: $pri, layer: $layer}')
        break
      fi
    done

    if [[ "$rdim" != "$prev_dim" && -n "$prev_dim" ]]; then
      # Flush previous dimension
      dimensions=$(echo "$dimensions" | jq --argjson rules "$dim_rules" --arg did "$prev_dim" --arg dname "$prev_dname" \
        '. + [{ id: $did, name: $dname, rules: $rules }]')
      dim_rules="[]"
    fi

    dim_rules=$(echo "$dim_rules" | jq --argjson rule "$rule_result" '. + [$rule]')
    prev_dim="$rdim"
    prev_dname="$rdname"
  done

  # Flush last dimension
  if [[ -n "$prev_dim" ]]; then
    dimensions=$(echo "$dimensions" | jq --argjson rules "$dim_rules" --arg did "$prev_dim" --arg dname "$prev_dname" \
      '. + [{ id: $did, name: $dname, rules: $rules }]')
  fi

  # Build AI checks array
  local ai_checks="[]"
  for r in "${RESULTS[@]}"; do
    local st; st=$(echo "$r" | jq -r '.status')
    if [[ "$st" == "ai" ]]; then
      ai_checks=$(echo "$ai_checks" | jq --argjson item "$r" '. + [$item]')
    fi
  done

  # Final report
  jq -n \
    --arg tool "$tool_name" \
    --arg version "$tool_version" \
    --arg spec "$SPEC_VERSION" \
    --arg ts "$timestamp" \
    --argjson summary "{\"total\": $total, \"passed\": $passed, \"failed\": $failed, \"skipped\": $skipped, \"ai_review\": $ai, \"warned\": $warned}" \
    --argjson scope "{\"partial\": $partial, \"dimension\": $(printf '%s' "$ACTIVE_DIMENSION" | jq -Rs .), \"layer\": $(printf '%s' "$ACTIVE_LAYER" | jq -Rs .), \"priority\": $(printf '%s' "$ACTIVE_PRIORITY" | jq -Rs .), \"rule\": $(printf '%s' "$ACTIVE_RULE" | jq -Rs .)}" \
    --argjson layers "$layers" \
    --argjson cert "{\"eligible\": $certification_eligible, \"partial\": $partial, \"agent_friendly\": $agent_friendly_json, \"agent_ready\": $agent_ready_json, \"agent_native\": $agent_native_json, \"reason\": $(printf '%s' "$certification_reason" | jq -Rs .)}" \
    --argjson dims "$dimensions" \
    --argjson ai "$ai_checks" \
    '{
      tool: $tool,
      version: $version,
      spec_version: $spec,
      timestamp: $ts,
      scope: $scope,
      summary: $summary,
      layers: $layers,
      certification: $cert,
      dimensions: $dims,
      ai_checks: $ai
    }'
}

# ═══════════════════════════════════════════════════════════
# Commands: check, snapshot, diff, ai-prompts
# ═══════════════════════════════════════════════════════════

cmd_check() {
  local cli="" dimension="" layer="" priority="" rule=""

  # First non-flag arg is the CLI
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dimension) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--dimension requires a value" "e.g. --dimension 01" 2
                   dimension="$2"; shift 2 ;;
      --layer)     [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--layer requires a value" "e.g. --layer core" 2
                   layer="$(echo "$2" | tr '[:upper:]' '[:lower:]')"; shift 2 ;;
      --priority)  [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--priority requires a value" "e.g. --priority p0" 2
                   priority="$(echo "$2" | tr '[:upper:]' '[:lower:]')"; shift 2 ;;  # lowercase
      --rule)      [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--rule requires a value" "e.g. --rule O1" 2
                   rule="$(echo "$2" | tr '[:lower:]' '[:upper:]')"; shift 2 ;;  # uppercase
      -*)          error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid: --dimension, --layer, --priority, --rule" 2 ;;
      *)           cli="$1"; shift ;;
    esac
  done

  case "$layer" in
    ""|core|recommended|ecosystem) ;;
    *) error_json "INVALID_ENUM" "Invalid layer: $layer" "Valid: core, recommended, ecosystem" 2 ;;
  esac

  if [[ -n "$rule" ]]; then
    local matched=false rule_dim="" rule_pri="" rule_layer_name=""
    for entry in "${RULE_REGISTRY[@]}"; do
      IFS='|' read -r rid rname rdim rdname rpri rule_layer_name rfunc <<< "$entry"
      [[ "$rid" != "$rule" ]] && continue
      matched=true
      rule_dim="$rdim"
      rule_pri="$(echo "$rpri" | tr '[:upper:]' '[:lower:]')"
      break
    done
    [[ "$matched" == true ]] || error_json "NOT_FOUND" "Unknown rule: $rule" "Use a valid rule id such as O1 or D15." 20
    [[ -n "$dimension" && "$dimension" != "$rule_dim" ]] && error_json "FILTER_CONFLICT" "Rule $rule is in dimension $rule_dim, not $dimension" "Remove either --rule or --dimension." 2
    [[ -n "$priority" && "$priority" != "$rule_pri" ]] && error_json "FILTER_CONFLICT" "Rule $rule has priority $rule_pri, not $priority" "Remove either --rule or --priority." 2
    [[ -n "$layer" && "$layer" != "$rule_layer_name" ]] && error_json "FILTER_CONFLICT" "Rule $rule is in layer $rule_layer_name, not $layer" "Remove either --rule or --layer." 2
  fi

  [[ -n "$cli" ]] || error_json "MISSING_PARAM" \
    "Missing required parameter: target CLI command" \
    "Usage: agent-cli-lint check <cli> [--dimension 01] [--layer core] [--priority p0] [--rule O1]" 2

  ACTIVE_DIMENSION="$dimension"
  ACTIVE_LAYER="$layer"
  ACTIVE_PRIORITY="$priority"
  ACTIVE_RULE="$rule"

  ensure_dirs
  discover_target "$cli"

  RESULTS=()

  local checked=0
  for entry in "${RULE_REGISTRY[@]}"; do
    IFS='|' read -r rid rname rdim rdname rpri rule_layer_name rfunc <<< "$entry"

    # Apply filters
    [[ -n "$dimension" && "$rdim" != "$dimension" ]] && continue
    [[ -n "$layer" && "$rule_layer_name" != "$layer" ]] && continue
    [[ -n "$priority" && "$(echo "$rpri" | tr '[:upper:]' '[:lower:]')" != "$priority" ]] && continue
    [[ -n "$rule" && "$rid" != "$rule" ]] && continue

    # Run check
    log "  [$rid] $rname ..."
    "$rfunc" 2>/dev/null || true
    checked=$((checked + 1))
  done

  if [[ $checked -eq 0 ]]; then
    error_json "NOT_FOUND" "No rules matched the filter" \
      "Check --dimension (01-11), --layer (core/recommended/ecosystem), --priority (p0/p1/p2), --rule (e.g. O1)" 20
  fi

  local report; report=$(build_report)

  # Extract summary for exit code decision
  local tool passed failed skipped total
  tool=$(echo "$report" | jq -r '.tool')
  passed=$(echo "$report" | jq -r '.summary.passed')
  failed=$(echo "$report" | jq -r '.summary.failed')
  skipped=$(echo "$report" | jq -r '.summary.skipped')
  total=$(echo "$report" | jq -r '.summary.total')

  if wants_json_output; then
    output_json "$report"
  else
    local partial af ar an
    partial=$(echo "$report" | jq -r '.scope.partial')
    af=$(echo "$report" | jq -r '.certification.agent_friendly')
    ar=$(echo "$report" | jq -r '.certification.agent_ready')
    an=$(echo "$report" | jq -r '.certification.agent_native')
    echo ""
    echo "  Agent-Friendly CLI Spec v$SPEC_VERSION — Lint Report"
    echo "  ─────────────────────────────────────────────"
    echo "  Tool:    $tool (v$(echo "$report" | jq -r '.version'))"
    echo "  Passed:  $passed / $total"
    echo "  Failed:  $failed"
    echo "  Skipped: $skipped"
    if [[ "$partial" == true ]]; then
      echo "  Scope:   partial report"
      echo "           filters: $(echo "$report" | jq -r '[.scope.dimension, .scope.layer, .scope.priority, .scope.rule] | map(select(. != "")) | if length == 0 then "none" else join(", ") end')"
    fi
    echo ""
    echo "  Certification:"
    if [[ "$partial" == true ]]; then
      echo "    not computed on filtered runs"
    else
      [[ "$af" == true ]] && echo "    ✓ Agent-Friendly (core layer complete)" || echo "    ✗ Agent-Friendly"
      [[ "$ar" == true ]] && echo "    ✓ Agent-Ready (core + recommended complete)" || echo "    ✗ Agent-Ready"
      [[ "$an" == true ]] && echo "    ✓ Agent-Native (all layers complete)" || echo "    ✗ Agent-Native"
    fi
    echo ""
    echo "  Layers:"
    for lname in core recommended ecosystem; do
      local leligible lcompliant lsummary lselected
      leligible=$(echo "$report" | jq -r --arg lname "$lname" '.layers[] | select(.name == $lname) | .eligible')
      lcompliant=$(echo "$report" | jq -r --arg lname "$lname" '.layers[] | select(.name == $lname) | .compliant')
      lselected=$(echo "$report" | jq -r --arg lname "$lname" '.layers[] | select(.name == $lname) | .summary.selected')
      lsummary=$(echo "$report" | jq -r --arg lname "$lname" '.layers[] | select(.name == $lname) | "\(.summary.passed)/\(.summary.checked) passed, \(.summary.failed) failed, \(.summary.skipped) skipped"')
      if [[ "$leligible" == true ]]; then
        [[ "$lcompliant" == true ]] && echo "    ✓ $lname ($lsummary)" || echo "    ✗ $lname ($lsummary)"
      elif [[ "${lselected:-0}" -gt 0 ]]; then
        echo "    · $lname (partial: $lsummary)"
      else
        echo "    · $lname (not in scope)"
      fi
    done
    echo ""

    # Show failures
    if [[ "$failed" -gt 0 ]]; then
      echo "  Failures:"
      for lname in core recommended ecosystem; do
        local layer_failures
        layer_failures=$(echo "$report" | jq -r --arg lname "$lname" '
          [.dimensions[].rules[] | select(.status == "fail" and .layer == $lname) |
            "    [\(.priority)] \(.id) \(.name): \(.detail)"] | .[]?')
        [[ -z "$layer_failures" ]] && continue
        echo "    $lname:"
        echo "$layer_failures"
      done
      echo ""
    fi
  fi

  # Exit code: 0 if all pass, 1 if failures
  [[ "$failed" -eq 0 ]] && exit 0 || exit 1
}

cmd_snapshot() {
  local cli="${1:-}"
  [[ -n "$cli" ]] || error_json "MISSING_PARAM" "Missing: target CLI" "Usage: agent-cli-lint snapshot <cli>" 2

  ensure_dirs
  discover_target "$cli"

  local tool_name; tool_name=$(_get_tool_name)
  local snap_dir="$SNAPSHOTS_DIR/$tool_name"
  mkdir -p "$snap_dir"

  # Save --describe if available, otherwise save --help
  if _has_describe_schema; then
    echo "$DESCRIBE_CACHE" | jq '.' > "$snap_dir/schema.json"
  else
    echo "$HELP_CACHE" | jq '.' > "$snap_dir/schema.json"
  fi
  log "Snapshot saved: $snap_dir/schema.json"

  if wants_json_output; then
    output_json "$(jq -n --arg dir "$snap_dir" --arg tool "$tool_name" '{snapshot: $dir, tool: $tool}')"
  fi
}

cmd_diff() {
  local cli="${1:-}"
  [[ -n "$cli" ]] || error_json "MISSING_PARAM" "Missing: target CLI" "Usage: agent-cli-lint diff <cli>" 2

  ensure_dirs
  discover_target "$cli"

  local tool_name; tool_name=$(_get_tool_name)
  local snap_dir="$SNAPSHOTS_DIR/$tool_name"

  [[ -f "$snap_dir/schema.json" ]] || error_json "NOT_FOUND" \
    "No snapshot for $tool_name" \
    "Run: agent-cli-lint snapshot $cli" 20

  local old_cmds new_cmds
  old_cmds=$(jq -r '[.commands[]?.name] | sort | .[]' "$snap_dir/schema.json" 2>/dev/null)
  new_cmds=$(echo "$DESCRIBE_CACHE" | jq -r '[.commands[]?.name] | sort | .[]' 2>/dev/null)

  local added removed
  added=$(comm -13 <(echo "$old_cmds") <(echo "$new_cmds") | paste -sd',' -)
  removed=$(comm -23 <(echo "$old_cmds") <(echo "$new_cmds") | paste -sd',' -)

  local breaking=false
  [[ -n "$removed" ]] && breaking=true

  if wants_json_output; then
    output_json "$(jq -n --arg added "$added" --arg removed "$removed" --argjson breaking "$breaking" \
      '{added: $added, removed: $removed, breaking: $breaking}')"
  else
    echo "  Snapshot diff for $tool_name:"
    [[ -n "$added" ]]   && echo "    Added:   $added"
    [[ -n "$removed" ]] && echo "    Removed: $removed (BREAKING)"
    [[ -z "$added" && -z "$removed" ]] && echo "    No changes"
  fi

  [[ "$breaking" == true ]] && exit 1 || exit 0
}

cmd_ai_prompts() {
  local cli="${1:-}"
  [[ -n "$cli" ]] || error_json "MISSING_PARAM" "Missing: target CLI" "Usage: agent-cli-lint ai-prompts <cli>" 2

  discover_target "$cli"

  local list_cmd; list_cmd=$(find_list_command)
  local all_cmds; all_cmds=$(_get_command_names | paste -sd', ' -)
  local src_dir="$TARGET_DIR"
  local test_cmd=""
  [[ -n "$list_cmd" ]] && test_cmd="$cli $list_cmd --json"

  # Build grep commands in variables (avoid nested quoting hell)
  local grep_env="grep -rE '(HOME|XDG_|\.config/|\.local/|process\.env|getenv)' $src_dir --include='*.ts' --include='*.sh' --include='*.py' --include='*.js' 2>/dev/null || echo 'NONE'"
  local grep_update="grep -riE '(auto.?update|self.?update|check.?update|fetch.*latest|upgrade.*silent)' $src_dir --include='*.ts' --include='*.sh' --include='*.py' --include='*.js' 2>/dev/null || echo 'NONE'"
  local grep_errors="grep -rn '(catch|rescue|except|trap|\.catch\(|try {)' $src_dir --include='*.ts' --include='*.sh' --include='*.py' --include='*.js' 2>/dev/null | head -20 || true"

  output_json "$(jq -n \
    --arg cli "$cli" \
    --arg test_cmd "$test_cmd" \
    --arg cmds "$all_cmds" \
    --arg grep_env "$grep_env" \
    --arg grep_update "$grep_update" \
    --arg grep_errors "$grep_errors" \
    '[
      {
        id: "I2",
        name: "No positional ambiguity",
        steps: [
          {command: ($cli + " --describe"), capture: "schema"},
          {action: "analyze", target: "schema.commands[].parameters — check positional args"},
          {action: "judge", criteria: "Each positional arg has fixed meaning regardless of other args"}
        ],
        pass_if: "No positional arg changes meaning based on context",
        fail_if: "Same positional slot means different things depending on other args"
      },
      {
        id: "I8",
        name: "No implicit state",
        steps: [
          {command: $grep_env, capture: "env_refs"},
          {command: ($cli + " --describe"), capture: "schema"},
          {action: "compare", target: "env_refs vs schema declared env vars"},
          {action: "judge", criteria: "All env/config dependencies must be declared in --describe"}
        ],
        pass_if: "All env/config dependencies declared in schema, or none exist",
        fail_if: "Behavior depends on undeclared env vars or hidden config files"
      },
      {
        id: "C7",
        name: "Idempotency",
        steps: [
          {command: $test_cmd, capture: "run1"},
          {command: $test_cmd, capture: "run2"},
          {action: "diff", target: "run1 vs run2 (ignore timestamps)"},
          {action: "repeat_for", target: ("Non-destructive commands: " + $cmds)}
        ],
        pass_if: "Identical output on repeated runs (excluding timestamps)",
        fail_if: "Output differs between identical runs unexpectedly"
      },
      {
        id: "S5",
        name: "No auto-upgrade",
        steps: [
          {command: $grep_update, capture: "update_refs"},
          {action: "judge", criteria: "No silent auto-update. Explicit update commands are OK."}
        ],
        pass_if: "No auto-update code, or only explicit user-triggered updates",
        fail_if: "Silent background update or auto-download of new versions"
      },
      {
        id: "G5",
        name: "Output redaction",
        steps: [
          {command: $test_cmd, capture: "output"},
          {action: "scan", target: "output for emails, phones, API keys, SSNs"},
          {action: "judge", criteria: "PII should be redacted in --json output"}
        ],
        pass_if: "No PII in output, or PII is masked",
        fail_if: "Raw PII appears unmasked in --json output"
      },
      {
        id: "G9",
        name: "Fail-closed",
        steps: [
          {command: $grep_errors, capture: "error_handlers"},
          {command: ($cli + " --describe"), capture: "schema"},
          {action: "judge", criteria: "Guard/validation crashes must DENY, not silently ALLOW"}
        ],
        pass_if: "Guard errors cause rejection (exit non-zero with error JSON)",
        fail_if: "Guard errors swallowed, command proceeds anyway"
      }
    ]')"
}

# ═══════════════════════════════════════════════════════════
# Main Router
# ═══════════════════════════════════════════════════════════

main() {
  # G9: Fail-closed
  trap 'error_json "INTERNAL_ERROR" "Unexpected error" "Report: agent-cli-lint issue create --type bug --message \"internal error\"" 1' ERR

  # Parse global flags
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json|--agent)
                   OUTPUT_JSON=true
                   FORCE_HUMAN=false
                   shift ;;
      --human)     FORCE_HUMAN=true
                   OUTPUT_JSON=false
                   shift ;;
      --fields)    [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--fields requires a value" "" 2
                   FIELDS="$2"; shift 2 ;;
      --quiet)     QUIET=true; shift ;;
      --brief)     cmd_brief; exit 0 ;;
      --help|-h)   cmd_help; exit 0 ;;
      --describe)  cmd_describe; exit 0 ;;
      --version)   echo "$VERSION"; exit 0 ;;
      *)           args+=("$1"); shift ;;
    esac
  done

  set -- "${args[@]+"${args[@]}"}"

  local cmd="${1:-}"
  shift 2>/dev/null || true

  case "$cmd" in
    check)      cmd_check "$@" ;;
    snapshot)   cmd_snapshot "$@" ;;
    diff)       cmd_diff "$@" ;;
    ai-prompts) cmd_ai_prompts "$@" ;;
    issue)      cmd_issue "$@" ;;
    skills)     cmd_skills "$@" ;;
    "")         error_json "MISSING_COMMAND" "No command specified" \
                  "Commands: check, snapshot, diff, ai-prompts, issue, skills" 2 ;;
    *)          error_json "UNKNOWN_COMMAND" "Unknown command: $cmd" \
                  "Commands: check, snapshot, diff, ai-prompts, issue, skills" 2 ;;
  esac
}

main "$@"
