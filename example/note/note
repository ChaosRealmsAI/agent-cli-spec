#!/usr/bin/env bash
# note — Local Note-Taking CLI
# Agent-Native CLI (Phase 1-3 implementation)
set -euo pipefail

VERSION="0.1.0"
NOTE_DIR="${NOTE_DIR:-$HOME/.note}"
DATA_FILE="$NOTE_DIR/notes.json"
ISSUES_DIR="$NOTE_DIR/issues"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# ═══════════════════════════════════════════════════════════
# [C1/C2] Composability: stdout = data only, stderr = logs
# ═══════════════════════════════════════════════════════════
QUIET=false
HUMAN=false
log() { [[ "$QUIET" == true ]] && return; echo "$*" >&2; }

# ═══════════════════════════════════════════════════════════
# [E1/E4/E5/E7] Structured Error to stderr, never interactive
# ═══════════════════════════════════════════════════════════
error_json() {
  local code="$1" message="$2" suggestion="${3:-}" exit_code="${4:-1}"
  local json
  json=$(jq -nc \
    --arg code "$code" \
    --arg message "$message" \
    --arg suggestion "$suggestion" \
    '{error: true, code: $code, message: $message} + (if $suggestion != "" then {suggestion: $suggestion} else {} end)')
  echo "$json" >&2
  exit "$exit_code"
}

# ═══════════════════════════════════════════════════════════
# [G2] Reject secrets in parameters
# ═══════════════════════════════════════════════════════════
check_secret() {
  local val="$1" param="$2"
  if [[ "$val" =~ ^(sk-|pk-|ghp_|gho_|github_pat_|xoxb-|xoxp-|AKIA) ]] ||
     [[ "$val" =~ ^eyJ[A-Za-z0-9] ]]; then
    error_json "SECRET_DETECTED" \
      "Parameter --$param looks like an API key or token" \
      "Never pass secrets as CLI arguments. Use environment variables instead." 1
  fi
}

# [G3] Reject dangerous file paths
check_path() {
  local val="$1" param="$2"
  if [[ "$val" =~ \.\.\/ ]] || [[ "$val" =~ \/\.\.\/ ]]; then
    error_json "PATH_TRAVERSAL" \
      "Parameter --$param contains path traversal" \
      "Use paths without .. components." 1
  fi
  local base; base=$(basename "$val" 2>/dev/null || echo "$val")
  if [[ "$base" =~ ^\.env ]] || [[ "$base" =~ \.key$ ]] || [[ "$base" =~ \.pem$ ]]; then
    error_json "SENSITIVE_PATH" \
      "Parameter --$param points to a sensitive file: $base" \
      "Avoid operating on credential or secret files." 1
  fi
}

# [G8] Reject shell metacharacters
check_shell_meta() {
  local val="$1" param="$2"
  if [[ "$val" =~ [\;\|\&\`] ]] || [[ "$val" =~ \$\( ]]; then
    error_json "SHELL_INJECTION" \
      "Parameter --$param contains shell metacharacters" \
      "Remove ; | & \` \$() from the value." 2
  fi
}

# [S4] Combined input validation
validate_input() {
  local val="$1" param="$2"
  check_shell_meta "$val" "$param"
  check_secret "$val" "$param"
}

# ═══════════════════════════════════════════════════════════
# Data layer
# ═══════════════════════════════════════════════════════════
ensure_data() {
  mkdir -p "$NOTE_DIR" "$ISSUES_DIR"
  [[ -f "$DATA_FILE" ]] || echo '[]' > "$DATA_FILE"
}

gen_id() {
  echo "n-$(date +%s)-$((RANDOM % 1000))"
}

# ═══════════════════════════════════════════════════════════
# [R1/R2/R3] Load agent context for response enrichment
# ═══════════════════════════════════════════════════════════
load_rules_json() {
  local rules=()
  if [[ -d "$SCRIPT_DIR/agent/rules" ]]; then
    for f in "$SCRIPT_DIR/agent/rules"/*.md; do
      [[ -f "$f" ]] || continue
      local name; name=$(basename "$f" .md)
      local content; content=$(cat "$f")
      rules+=("$(jq -nc --arg n "$name" --arg c "$content" '{name:$n, content:$c}')")
    done
  fi
  local IFS=','
  echo "[${rules[*]:-}]"
}

load_skills_json() {
  local skills=()
  if [[ -d "$SCRIPT_DIR/agent/skills" ]]; then
    for f in "$SCRIPT_DIR/agent/skills"/*.md; do
      [[ -f "$f" ]] || continue
      local name; name=$(basename "$f" .md)
      # Extract description from YAML frontmatter
      local desc=""
      desc=$(sed -n '/^---$/,/^---$/{ /^description:/s/^description: *//p; }' "$f")
      skills+=("$(jq -nc --arg n "$name" --arg d "$desc" --arg cmd "note skills $name" \
        '{name:$n, description:$d, command:$cmd}')")
    done
  fi
  local IFS=','
  echo "[${skills[*]:-}]"
}

ISSUE_HINT="Any problem, bad output, or confusion -- run: note issue create --type <bug|requirement|suggestion|bad-output> --message '...'"

# Wrap a result with rules/skills/issue context
wrap_response() {
  local result="$1"
  local rules_json; rules_json=$(load_rules_json)
  local skills_json; skills_json=$(load_skills_json)
  jq -nc \
    --argjson result "$result" \
    --argjson rules "$rules_json" \
    --argjson skills "$skills_json" \
    --arg issue "$ISSUE_HINT" \
    '{result: $result, rules: $rules, skills: $skills, issue: $issue}'
}

# ═══════════════════════════════════════════════════════════
# Output helpers
# ═══════════════════════════════════════════════════════════
output_result() {
  local result="$1"
  if [[ "$HUMAN" == true ]]; then
    # Human-friendly: just print the result without envelope
    echo "$result" | jq '.'
  else
    # Agent mode: full envelope with rules/skills/issue
    wrap_response "$result"
  fi
}

output_one_human() {
  local data="$1"
  echo "$data" | jq -r '"  ID:    \(.id)\n  Title: \(.title)\n  Body:  \(.body)\n  Tags:  \(.tags | join(", "))\n  Date:  \(.created_at)"'
}

output_list_human() {
  local data="$1"
  local count; count=$(echo "$data" | jq 'length')
  if [[ "$count" -eq 0 ]]; then
    log "  (no notes)"
  else
    echo "$data" | jq -r '.[] | "  \(.id)  \(.title)  [\(.tags | join(","))]"'
    log "  ($count notes)"
  fi
}

# ═══════════════════════════════════════════════════════════
# [D1/D3/D11] --help: structured JSON self-description
# ═══════════════════════════════════════════════════════════
cmd_help() {
  local brief=""
  [[ -f "$SCRIPT_DIR/agent/brief.md" ]] && brief=$(cat "$SCRIPT_DIR/agent/brief.md")

  local rules_json; rules_json=$(load_rules_json)
  local skills_json; skills_json=$(load_skills_json)

  if [[ "$HUMAN" == true ]]; then
    echo "note $VERSION -- Local Note-Taking CLI"
    echo ""
    echo "Commands:"
    echo "  add      Create a new note"
    echo "  list     List all notes"
    echo "  show     Show a note by ID"
    echo "  search   Search notes by keyword"
    echo "  delete   Delete a note (destructive, requires --yes)"
    echo "  issue    Feedback system (create/list/show/close/transition)"
    echo "  skills   View skill documents"
    echo ""
    echo "Global flags:"
    echo "  --human    Human-friendly output"
    echo "  --agent    Explicit JSON mode (default)"
    echo "  --brief    One-paragraph identity"
    echo "  --version  Show version"
    echo "  --quiet    Suppress stderr"
    echo "  --fields   Filter output fields"
    echo "  --yes      Confirm destructive ops"
    echo "  --dry-run  Preview without executing"
    return
  fi

  jq -nc \
    --arg help "$brief" \
    --arg version "$VERSION" \
    --argjson rules "$rules_json" \
    --argjson skills "$skills_json" \
    --arg issue "$ISSUE_HINT" \
    '{
      help: $help,
      version: $version,
      commands: [
        {name:"add",    description:"Create a new note",     destructive:false,
         parameters:[
           {name:"title",type:"string",required:true, description:"Note title"},
           {name:"body", type:"string",required:true, description:"Note body text"},
           {name:"tags", type:"string",required:false,description:"Comma-separated tags"}
         ]},
        {name:"list",   description:"List all notes",        destructive:false,
         parameters:[]},
        {name:"show",   description:"Show a note by ID",     destructive:false,
         parameters:[
           {name:"id",type:"string",required:true,description:"Note ID"}
         ]},
        {name:"search", description:"Search notes by keyword",destructive:false,
         parameters:[
           {name:"query",type:"string",required:true,description:"Search keyword"}
         ]},
        {name:"delete", description:"Delete a note by ID",   destructive:true,
         parameters:[
           {name:"id",     type:"string", required:true, description:"Note ID"},
           {name:"yes",    type:"boolean",required:true, description:"Confirm deletion"},
           {name:"dry-run",type:"boolean",required:false,description:"Preview without executing"}
         ]},
        {name:"issue",  description:"Feedback system",       destructive:false,
         parameters:[]},
        {name:"skills", description:"View skill documents",  destructive:false,
         parameters:[
           {name:"name",type:"string",required:true,description:"Skill name"}
         ]}
      ],
      rules: $rules,
      skills: $skills,
      issue: $issue
    }'
}

# ═══════════════════════════════════════════════════════════
# [D15] --brief: reads agent/brief.md
# ═══════════════════════════════════════════════════════════
cmd_brief() {
  if [[ -f "$SCRIPT_DIR/agent/brief.md" ]]; then
    cat "$SCRIPT_DIR/agent/brief.md"
  else
    echo "note -- local note-taking CLI"
  fi
}

# ═══════════════════════════════════════════════════════════
# [D14] skills subcommand
# ═══════════════════════════════════════════════════════════
cmd_skills() {
  local name="${1:-}"

  # List all skills if no name given
  if [[ -z "$name" ]]; then
    local skills_json; skills_json=$(load_skills_json)
    if [[ "$HUMAN" == true ]]; then
      echo "Available skills:"
      echo "$skills_json" | jq -r '.[] | "  \(.name) -- \(.description)"'
    else
      local rules_json; rules_json=$(load_rules_json)
      jq -nc \
        --argjson skills "$skills_json" \
        --argjson rules "$rules_json" \
        --arg issue "$ISSUE_HINT" \
        '{result: $skills, rules: $rules, skills: $skills, issue: $issue}'
    fi
    return
  fi

  local skill_file="$SCRIPT_DIR/agent/skills/$name.md"
  if [[ ! -f "$skill_file" ]]; then
    error_json "NOT_FOUND" \
      "Skill not found: $name" \
      "Run: note skills  to list available skills" 20
  fi

  local content; content=$(cat "$skill_file")
  local rules_json; rules_json=$(load_rules_json)

  if [[ "$HUMAN" == true ]]; then
    echo "$content"
  else
    jq -nc \
      --arg name "$name" \
      --arg content "$content" \
      --argjson rules "$rules_json" \
      '{name: $name, content: $content, rules: $rules}'
  fi
}

# ═══════════════════════════════════════════════════════════
# Commands: add, list, show, search, delete
# ═══════════════════════════════════════════════════════════
cmd_add() {
  local title="" body="" tags_str=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --title) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --title requires a value" "Provide: --title <title>" 2
               title="$2"; shift 2 ;;
      --body)  [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --body requires a value" "Provide: --body <text>" 2
               body="$2"; shift 2 ;;
      --tags)  [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --tags requires a value" "Provide: --tags <t1,t2>" 2
               tags_str="$2"; shift 2 ;;
      *)       error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --title, --body, --tags" 2 ;;
    esac
  done

  # [I4] Missing required → structured error, never interactive
  [[ -n "$title" ]] || error_json "MISSING_REQUIRED" "Missing required parameter: --title" "Usage: note add --title <title> --body <text> [--tags <t1,t2>]" 2
  [[ -n "$body" ]]  || error_json "MISSING_REQUIRED" "Missing required parameter: --body" "Usage: note add --title <title> --body <text> [--tags <t1,t2>]" 2

  # [G1-G8] Validate inputs
  validate_input "$title" "title"
  validate_input "$body" "body"
  [[ -n "$tags_str" ]] && validate_input "$tags_str" "tags"

  ensure_data

  local id; id=$(gen_id)
  local created; created=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local tags_json="[]"
  if [[ -n "$tags_str" ]]; then
    tags_json=$(echo "$tags_str" | tr ',' '\n' | jq -R . | jq -s .)
  fi

  local new_entry
  new_entry=$(jq -nc \
    --arg id "$id" \
    --arg title "$title" \
    --arg body "$body" \
    --argjson tags "$tags_json" \
    --arg created_at "$created" \
    --arg updated_at "$created" \
    '{id:$id, title:$title, body:$body, tags:$tags, created_at:$created_at, updated_at:$updated_at}')

  jq --argjson entry "$new_entry" '. += [$entry]' "$DATA_FILE" > "$DATA_FILE.tmp" \
    && mv "$DATA_FILE.tmp" "$DATA_FILE"

  log "Note added: $id"

  if [[ "$HUMAN" == true ]]; then
    output_one_human "$new_entry"
  else
    output_result "$new_entry"
  fi
}

cmd_list() {
  ensure_data
  local data; data=$(cat "$DATA_FILE")

  if [[ "$HUMAN" == true ]]; then
    output_list_human "$data"
  else
    output_result "$data"
  fi
}

cmd_show() {
  local id=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --id requires a value" "Provide: --id <note-id>" 2
            id="$2"; shift 2 ;;
      -*)   error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --id" 2 ;;
      *)    # Allow first positional as id for convenience
            if [[ -z "$id" ]]; then id="$1"; shift
            else error_json "UNKNOWN_FLAG" "Unexpected argument: $1" "Usage: note show --id <id>" 2; fi ;;
    esac
  done

  [[ -n "$id" ]] || error_json "MISSING_REQUIRED" \
    "Missing required parameter: note ID" \
    "Usage: note show --id <id>" 2

  validate_input "$id" "id"
  ensure_data

  local entry; entry=$(jq --arg id "$id" '.[] | select(.id == $id)' "$DATA_FILE")
  [[ -n "$entry" ]] || error_json "NOT_FOUND" \
    "Note not found: $id" \
    "Use: note list  to see available note IDs" 20

  if [[ "$HUMAN" == true ]]; then
    output_one_human "$entry"
  else
    output_result "$entry"
  fi
}

cmd_search() {
  local query=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --query) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --query requires a value" "Provide: --query <keyword>" 2
               query="$2"; shift 2 ;;
      *)       error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --query" 2 ;;
    esac
  done

  [[ -n "$query" ]] || error_json "MISSING_REQUIRED" \
    "Missing required parameter: --query" \
    "Usage: note search --query <keyword>" 2

  validate_input "$query" "query"
  ensure_data

  local results
  results=$(jq --arg q "$query" \
    '[.[] | select(
      (.title | ascii_downcase | contains($q | ascii_downcase)) or
      (.body  | ascii_downcase | contains($q | ascii_downcase)) or
      (.tags  | map(ascii_downcase) | any(contains($q | ascii_downcase)))
    )]' "$DATA_FILE")

  if [[ "$HUMAN" == true ]]; then
    output_list_human "$results"
  else
    output_result "$results"
  fi
}

cmd_delete() {
  local id="" confirm=false dry_run=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --id)      [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --id requires a value" "Provide: --id <note-id>" 2
                 id="$2"; shift 2 ;;
      --yes)     confirm=true; shift ;;
      --dry-run) dry_run=true; shift ;;
      -*)        error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --id, --yes, --dry-run" 2 ;;
      *)         # Allow first positional as id
                 if [[ -z "$id" ]]; then id="$1"; shift
                 else error_json "UNKNOWN_FLAG" "Unexpected argument: $1" "Usage: note delete --id <id> --yes" 2; fi ;;
    esac
  done

  [[ -n "$id" ]] || error_json "MISSING_REQUIRED" \
    "Missing required parameter: note ID" \
    "Usage: note delete --id <id> --yes" 2

  validate_input "$id" "id"

  # [S1] Destructive op requires --yes
  if [[ "$confirm" != true ]]; then
    error_json "CONFIRMATION_REQUIRED" \
      "Destructive operation requires --yes flag" \
      "Add --yes to confirm deletion, or use --dry-run to preview." 1
  fi

  ensure_data

  local entry; entry=$(jq --arg id "$id" '.[] | select(.id == $id)' "$DATA_FILE")
  [[ -n "$entry" ]] || error_json "NOT_FOUND" \
    "Note not found: $id" \
    "Use: note list  to see available note IDs" 20

  # --dry-run previews without executing
  if [[ "$dry_run" == true ]]; then
    local preview
    preview=$(jq -nc --arg id "$id" --argjson entry "$entry" \
      '{dry_run: true, action: "delete", target: $id, entry: $entry}')
    if [[ "$HUMAN" == true ]]; then
      log "[DRY RUN] Would delete:"
      output_one_human "$entry"
    else
      output_result "$preview"
    fi
    return 0
  fi

  jq --arg id "$id" '[.[] | select(.id != $id)]' "$DATA_FILE" > "$DATA_FILE.tmp" \
    && mv "$DATA_FILE.tmp" "$DATA_FILE"

  log "Deleted: $id"
  local deleted_result
  deleted_result=$(jq -nc --arg id "$id" '{deleted: $id}')
  if [[ "$HUMAN" == true ]]; then
    echo "  Deleted: $id"
  else
    output_result "$deleted_result"
  fi
}

# ═══════════════════════════════════════════════════════════
# [F1-F8] Issue subcommand — full feedback system
# ═══════════════════════════════════════════════════════════
cmd_issue() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    create)     cmd_issue_create "$@" ;;
    list)       cmd_issue_list "$@" ;;
    show)       cmd_issue_show "$@" ;;
    close)      cmd_issue_transition "$@" --status closed ;;
    transition) cmd_issue_transition "$@" ;;
    "")         error_json "MISSING_REQUIRED" \
                  "Missing subcommand for issue" \
                  "Usage: note issue <create|list|show|close|transition>" 2 ;;
    *)          error_json "UNKNOWN_COMMAND" \
                  "Unknown issue subcommand: $subcmd" \
                  "Available: create, list, show, close, transition" 2 ;;
  esac
}

cmd_issue_create() {
  local type="" message=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)    [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --type requires a value" "" 2
                 type="$2"; shift 2 ;;
      --message) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "Flag --message requires a value" "" 2
                 message="$2"; shift 2 ;;
      *)         error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --type, --message" 2 ;;
    esac
  done

  [[ -n "$type" ]]    || error_json "MISSING_REQUIRED" "Missing: --type" "Options: bug, requirement, suggestion, bad-output" 2
  [[ -n "$message" ]] || error_json "MISSING_REQUIRED" "Missing: --message" "Describe the issue." 2

  # [F3] Validate type
  case "$type" in
    bug|requirement|suggestion|bad-output) ;;
    *) error_json "INVALID_ENUM" \
         "Invalid issue type: $type" \
         "Valid types: bug, requirement, suggestion, bad-output" 2 ;;
  esac

  validate_input "$message" "message"
  ensure_data

  # Generate sequential ID
  local max_id=0
  for f in "$ISSUES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    local num; num=$(basename "$f" .json)
    if [[ "$num" =~ ^[0-9]+$ ]] && [[ "$num" -gt "$max_id" ]]; then
      max_id="$num"
    fi
  done
  local next_id; next_id=$(printf "%03d" $((max_id + 1)))

  local now; now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  # [F2/F7] Structured issue with all required fields
  local issue
  issue=$(jq -nc \
    --arg id "$next_id" \
    --arg type "$type" \
    --arg status "open" \
    --arg message "$message" \
    --arg version "$VERSION" \
    --arg created_at "$now" \
    --arg updated_at "$now" \
    '{id:$id, type:$type, status:$status, message:$message,
     context:{version:$version}, created_at:$created_at, updated_at:$updated_at}')

  echo "$issue" > "$ISSUES_DIR/$next_id.json"

  log "Issue created: $next_id"
  if [[ "$HUMAN" == true ]]; then
    echo "  Created issue $next_id ($type): $message"
  else
    output_result "$issue"
  fi
}

cmd_issue_list() {
  local filter_type="" filter_status=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type)   [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--type requires a value" "" 2
                filter_type="$2"; shift 2 ;;
      --status) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--status requires a value" "" 2
                filter_status="$2"; shift 2 ;;
      *)        error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --type, --status" 2 ;;
    esac
  done

  ensure_data

  local issues="[]"
  for f in "$ISSUES_DIR"/*.json; do
    [[ -f "$f" ]] || continue
    issues=$(echo "$issues" | jq --slurpfile entry "$f" '. + $entry')
  done

  # Apply filters
  if [[ -n "$filter_type" ]]; then
    issues=$(echo "$issues" | jq --arg t "$filter_type" '[.[] | select(.type == $t)]')
  fi
  if [[ -n "$filter_status" ]]; then
    issues=$(echo "$issues" | jq --arg s "$filter_status" '[.[] | select(.status == $s)]')
  fi

  if [[ "$HUMAN" == true ]]; then
    local count; count=$(echo "$issues" | jq 'length')
    if [[ "$count" -eq 0 ]]; then
      log "  (no issues)"
    else
      echo "$issues" | jq -r '.[] | "  \(.id)  [\(.status)]  \(.type): \(.message)"'
      log "  ($count issues)"
    fi
  else
    output_result "$issues"
  fi
}

cmd_issue_show() {
  local id=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -*)  error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Usage: note issue show <id>" 2 ;;
      *)   if [[ -z "$id" ]]; then id="$1"; shift
           else error_json "UNKNOWN_FLAG" "Unexpected argument: $1" "Usage: note issue show <id>" 2; fi ;;
    esac
  done

  [[ -n "$id" ]] || error_json "MISSING_REQUIRED" "Missing: issue ID" "Usage: note issue show <id>" 2

  # Normalize id to padded format
  local padded; padded=$(printf "%03d" "$id" 2>/dev/null || echo "$id")
  local file="$ISSUES_DIR/$padded.json"
  [[ -f "$file" ]] || error_json "NOT_FOUND" "Issue not found: $id" "Use: note issue list  to see available issues" 20

  local issue; issue=$(cat "$file")
  if [[ "$HUMAN" == true ]]; then
    echo "$issue" | jq -r '"  ID:      \(.id)\n  Type:    \(.type)\n  Status:  \(.status)\n  Message: \(.message)\n  Created: \(.created_at)"'
  else
    output_result "$issue"
  fi
}

cmd_issue_transition() {
  local id="" new_status=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status) [[ $# -ge 2 ]] || error_json "MISSING_VALUE" "--status requires a value" "" 2
                new_status="$2"; shift 2 ;;
      -*)       error_json "UNKNOWN_FLAG" "Unknown flag: $1" "Valid flags: --status" 2 ;;
      *)        if [[ -z "$id" ]]; then id="$1"; shift
                else error_json "UNKNOWN_FLAG" "Unexpected argument: $1" "" 2; fi ;;
    esac
  done

  [[ -n "$id" ]]         || error_json "MISSING_REQUIRED" "Missing: issue ID" "Usage: note issue transition <id> --status <status>" 2
  [[ -n "$new_status" ]] || error_json "MISSING_REQUIRED" "Missing: --status" "Options: open, in-progress, resolved, closed" 2

  case "$new_status" in
    open|in-progress|resolved|closed) ;;
    *) error_json "INVALID_ENUM" "Invalid status: $new_status" "Valid: open, in-progress, resolved, closed" 2 ;;
  esac

  local padded; padded=$(printf "%03d" "$id" 2>/dev/null || echo "$id")
  local file="$ISSUES_DIR/$padded.json"
  [[ -f "$file" ]] || error_json "NOT_FOUND" "Issue not found: $id" "Use: note issue list" 20

  local now; now=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local updated
  updated=$(jq --arg s "$new_status" --arg u "$now" '.status = $s | .updated_at = $u' "$file")
  echo "$updated" > "$file"

  log "Issue $padded transitioned to $new_status"
  if [[ "$HUMAN" == true ]]; then
    echo "  Issue $padded -> $new_status"
  else
    output_result "$updated"
  fi
}

# ═══════════════════════════════════════════════════════════
# Main router
# ═══════════════════════════════════════════════════════════
main() {
  # [G9] Fail-closed
  trap 'error_json "INTERNAL_ERROR" "Unexpected error" "Report via: note issue create --type bug --message \"internal error\"" 1' ERR

  # Parse global flags
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --human)    HUMAN=true; shift ;;
      --json|--agent) HUMAN=false; shift ;;
      --quiet)    QUIET=true; shift ;;
      --brief)    cmd_brief; exit 0 ;;
      --help|-h)  cmd_help; exit 0 ;;
      --version)  echo "$VERSION"; exit 0 ;;
      --yes|--dry-run|--fields)
                  # These are command-level flags; pass them through
                  args+=("$1"); shift ;;
      *)          args+=("$1"); shift ;;
    esac
  done

  set -- "${args[@]+"${args[@]}"}"

  local cmd="${1:-}"
  shift 2>/dev/null || true

  case "$cmd" in
    add)     cmd_add "$@" ;;
    list)    cmd_list "$@" ;;
    show)    cmd_show "$@" ;;
    search)  cmd_search "$@" ;;
    delete)  cmd_delete "$@" ;;
    issue)   cmd_issue "$@" ;;
    skills)  cmd_skills "$@" ;;
    "")      error_json "MISSING_COMMAND" \
               "No command specified" \
               "Available commands: add, list, show, search, delete, issue, skills. Run: note --help" 2 ;;
    *)       error_json "UNKNOWN_COMMAND" \
               "Unknown command: $cmd" \
               "Available commands: add, list, show, search, delete, issue, skills" 2 ;;
  esac
}

main "$@"
